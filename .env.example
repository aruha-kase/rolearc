# =============================================================
# RoleArc 環境変数テンプレート
# このファイルをコピーして .env を作成し、各値を埋めてください:
#   cp .env.example .env
# .env は .gitignore 済みなのでコミットされません。
# =============================================================

# --- Supabase（DB / 認証 / Realtime） -------------------------
# Supabaseダッシュボード → Project Settings → API から取得
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOi...   # anon public key

# --- Cloudflare R2（画像・動画ストレージ） ---------------------
# 公開URL（R2バケットの公開ドメイン or カスタムドメイン）
# クライアントから参照するため VITE_ プレフィックスが必要
VITE_R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev

# 署名付きURL発行・削除に使うサーバー側シークレット
# （Vercelの環境変数にのみ設定。クライアントには露出しない）
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_BUCKET_NAME=rolearc
